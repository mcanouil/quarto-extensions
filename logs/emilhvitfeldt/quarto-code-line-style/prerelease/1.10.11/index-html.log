pandoc 

  to: html
  output-file: index.html
  standalone: true
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  toc: true
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  title: code-line-style
  subtitle: Named visual treatments for code blocks in Quarto
  

Output created: index.html


