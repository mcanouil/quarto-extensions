pandoc 

  to: latex
  output-file: template.tex
  template: _extensions/aaai2026/aaai2026-template.latex
  standalone: true
  pdf-engine: pdflatex
  variables:
    graphics: true
    tables: true
    secnumdepth: 2
  default-image-extension: pdf
  number-sections: true
  cite-method: natbib
  

metadata

  block-headings: true
  number-depth: 2
  biblio-style: aaai2026.bst
  fig-cap-location: bottom
  tbl-cap-location: bottom
  engines:
    - path: /opt/quarto/share/extension-subtrees/julia-engine/_extensions/julia-engine/julia-engine.js
  title: Example article for AAAI 2026 using Quarto
  author:
    - name: Max Mustermann
      orcid: 0000-0000-0000-0000
      email: name@example.com
      affiliation:
        - ref: 1
    - name: Author Two
      orcid: 0000-0000-0000-0001
      email: name2@example.com
      affiliation:
        - ref: 1
  affiliations:
    - id: 1
      name: Association for the Advancement of Artificial Intelligence
      department: Data Science and its Applications
      address: 1101 Pennsylvania Ave, NW Suite 300
      city: Washington
      country: USA
      state: DC
      url: https://aaai.org
  abstract: |
    AAAI creates proceedings, working notes, and technical reports directly from electronic source furnished by the authors. To ensure that all papers in the publication have a uniform appearance, authors must adhere to the following instructions.
  links:
    - name: Code
      url: https://aaai.org/example/code
    - name: Datasets
      url: https://aaai.org/example/datasets
  keywords:
    - template
    - demo
  bibliography:
    - bibliography.bib
  header-includes:
    - \usepackage{amsmath,amssymb}
    - \usepackage{booktabs}
  

