

pandoc 

  to: html
  output-file: index.html
  standalone: true
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  title-block-banner: '#222222'
  theme:
    - default
    - ../../style.scss
  linkcolor: '#ff3e00'
  callout-appearance: simple
  title: 'Examples: time series'
  author: James Goldie
  date: last-modified
  quarto-svelte:
    use:
      - TimeSeriesChart.svelte
  resources:
    - '*.csv'
  

Output created: ../../_site/examples/time-series/index.html


