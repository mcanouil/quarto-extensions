pandoc 

  to: html
  output-file: example.html
  standalone: true
  embed-resources: true
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  variables: {}
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  engines:
    - path: /opt/quarto/share/extension-subtrees/julia-engine/_extensions/julia-engine/julia-engine.js
  title: Quarto Watermark Extension Example
  abstract: This is an example document of quarto watermark extension.
  watermark:
    text: Watermark
    size: 1
    angle: 15
    color: '#000000'
    opacity: 0.1
    cols: 10
    rows: 50
    col-space: 4
    row-space: 4
    z-index: -1
    html-font: system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', 'Noto Sans', 'Liberation Sans', Arial, sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', 'Noto Color Emoji'
    pdf-font: ETbb
  

Output created: example.html


