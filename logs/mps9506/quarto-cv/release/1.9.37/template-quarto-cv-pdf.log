pandoc 

  to: latex
  output-file: template.tex
  template: _extensions/quarto-cv/quarto-cv.tex
  standalone: true
  pdf-engine: lualatex
  variables:
    graphics: true
    tables: true
  default-image-extension: pdf
  toc: false
  

metadata

  block-headings: true
  linkcolor: blue
  urlcolor: blue
  geometry: margin=1in
  biblio-config: false
  engines:
    - path: /opt/quarto/share/extension-subtrees/julia-engine/_extensions/julia-engine/julia-engine.js
  title: CV
  author: William Gosset
  date: last-modified
  phone: 123-456-7890
  address: Guinness Brewery · Park Royal · London NW10 7RR, UK
  email: guinness@consumer-care.net
  fontsize: 11pt
  orcid: 0000-0002-1825-0097
  web: quarto.org
  fontawesome: 'yes'
  nocite: '@*'
  bibliography:
    peer: peer_bib.bib
    other: other_bib.bib
  csl: apa-cv.csl
  

