pandoc 

  to: html
  output-file: example.html
  standalone: true
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  variables: {}
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  title: Search-replace Example
  search-replace:
    +quarto: '[Quarto](https://quarto.org)'
    +qurl: https://quarto.org/docs
    +forml: $\alpha * \beta = \gamma$
    +pyth: 'Pythagoras'' theorem: $a^2 + b^2 = \dots$'
    .doo: '- doodledoo - '
    '--when-format--':
      html:
        +br: '`<br>`{=html}'
        +format: html
        +wewant: read on screen
      pdf:
        +br: '`\newline`{=latex}'
        +format: pdf
        +wewant: print on paper
    +dab: '**dab**'
    '!dua': '`duaaah`'
  

Output created: example.html


