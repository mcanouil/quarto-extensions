pandoc 

  to: html
  output-file: boxtypes.html
  standalone: true
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  variables: {}
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  engines:
    - path: /opt/quarto/share/extension-subtrees/julia-engine/_extensions/julia-engine/julia-engine.js
  title: Custom Numbered Blocks Extension
  search-replace:
    +rend: '`<div class=rendered>`{=html}'
    +/div: '`</div>`{=html}'
  extensions:
    custom-numbered-blocks:
      styles:
        txtbx:
          appearance: textbox
          sizes:
            margin: 1em
            padding: 1em
          color: '#aabbdd'
      classes:
        Box:
          style: txtbx
        ToDo: default
        TODOplain:
          boxtype: fallback
  crossref:
    chapters: false
  

Output created: boxtypes.html


