pandoc 

  to: beamer
  output-file: example.tex
  standalone: true
  pdf-engine: lualatex
  variables:
    graphics: true
    tables: true
  default-image-extension: pdf
  

metadata

  block-headings: true
  engines:
    - path: /opt/quarto/share/extension-subtrees/julia-engine/_extensions/julia-engine/julia-engine.js
  title: Fullframegraphics Example
  theme: metropolis
  aspectratio: 169
  


