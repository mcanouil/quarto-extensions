pandoc 

  to: latex
  output-file: template.tex
  standalone: true
  pdf-engine: lualatex
  variables:
    graphics: true
    tables: true
  default-image-extension: pdf
  

metadata

  block-headings: true
  date-format: long
  documentclass: article
  fontfamily: helvet
  fontsize: 12pt
  geometry:
    - left=2.5cm
    - right=2cm
    - top=2cm
    - bottom=2cm
  colorlinks: true
  header-includes:
    - |
      \usepackage{graphicx}
      \usepackage{xcolor}
      \usepackage[absolute,overlay]{textpos}
      \setlength{\TPHorizModule}{1cm}
      \setlength{\TPVertModule}{1cm}
      \definecolor{fublue}{HTML}{004659}
      \definecolor{fulime}{HTML}{CCFF00}
      \setlength{\parskip}{0.5em}
      \setlength{\parindent}{0pt}
  engines:
    - path: /opt/quarto/share/extension-subtrees/julia-engine/_extensions/julia-engine/julia-engine.js
  sender-name: Dr. Your Name
  sender-department: Your Department
  sender-institute: Your Institute
  sender-faculty: Your Faculty
  sender-address: Your Street Address
  sender-city: Postal Code City
  sender-phone: +49 30 12345678
  sender-email: your.email@fu-berlin.de
  recipient-organization: Organization Name
  recipient-department: ''
  recipient-name: Recipient Name
  recipient-address: Street Address
  recipient-city: Postal Code City
  letter-subject: Subject Line
  letter-lang: en
  


