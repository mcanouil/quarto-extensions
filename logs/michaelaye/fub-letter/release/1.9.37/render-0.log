pandoc 

  to: latex
  output-file: template.tex
  standalone: true
  pdf-engine: lualatex
  variables:
    graphics: true
    tables: true
  default-image-extension: pdf
  

metadata

  block-headings: true
  date-format: long
  documentclass: article
  fontfamily: helvet
  fontsize: 12pt
  geometry:
    - left=2.5cm
    - right=2cm
    - top=2cm
    - bottom=2cm
  colorlinks: true
  header-includes:
    - |
      \usepackage{graphicx}
      \usepackage{xcolor}
      \usepackage[absolute,overlay]{textpos}
      \setlength{\TPHorizModule}{1cm}
      \setlength{\TPVertModule}{1cm}
      \definecolor{fublue}{HTML}{004659}
      \definecolor{fulime}{HTML}{CCFF00}
      \setlength{\parskip}{0.5em}
      \setlength{\parindent}{0pt}
  engines:
    - path: /opt/quarto/share/extension-subtrees/julia-engine/_extensions/julia-engine/julia-engine.js
  sender-name: Dr. Max Mustermann
  sender-department: FR Beispielabteilung
  sender-institute: Institut für Beispielforschung
  sender-faculty: Fachbereich Beispielwissenschaften
  sender-address: Musterstraße 123
  sender-city: 14195 Berlin
  sender-phone: +49 30 12345678
  sender-email: max.mustermann@fu-berlin.de
  recipient-organization: Beispielorganisation
  recipient-department: Abteilung Forschung
  recipient-name: Prof. Dr. Erika Beispiel
  recipient-address: Beispielweg 45
  recipient-city: 12345 Musterstadt
  letter-subject: Bewerbung um eine Forschungsposition
  letter-lang: de
  


