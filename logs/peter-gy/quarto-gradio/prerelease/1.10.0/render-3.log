pandoc 

  to: html
  output-file: index.html
  standalone: true
  title-prefix: Quarto 🔹🔸 Gradio
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  toc: true
  css:
    - ../../styles.css
  variables: {}
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  engines:
