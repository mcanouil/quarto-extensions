pandoc 

  to: html
  output-file: index.html
  standalone: true
  title-prefix: Quarto 🔹🔸 Gradio
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  toc: true
  css:
    - ../../styles.css
  variables: {}
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  engines:
    - path: /opt/quarto/share/extension-subtrees/julia-engine/_extensions/julia-engine/julia-engine.js
  code-copy: true
  theme: darkly
  grid:
    sidebar-width: 300px
    body-width: 800px
    margin-width: 200px
  image: ../../public/quarto-gradio-bg.png
  gradio:
    cdn: https://peter-gy.github.io/static/npm/gradio-lite
  title: 📚 Define Multiple Apps
  

