pandoc 

  to: html
  output-file: attributes-block.html
  standalone: true
  title-prefix: Quarto 🔹🔸 Gradio
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  toc: true
  css:
    - ../../styles.css
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  code-copy: true
  theme: darkly
  grid:
    sidebar-width: 300px
    body-width: 800px
    margin-width: 200px
  image: ../../public/quarto-gradio-bg.png
  gradio:
    cdn: https://peter-gy.github.io/static/npm/gradio-lite
  

Output created: ../../_site/guide/enable-coding-playground/attributes-block.html


