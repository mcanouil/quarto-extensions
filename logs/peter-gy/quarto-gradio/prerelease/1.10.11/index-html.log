pandoc 

  to: html
  output-file: index.html
  standalone: true
  title-prefix: Quarto 🔹🔸 Gradio
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  toc: true
  css:
    - styles.css
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  code-copy: true
  theme: darkly
  grid:
    sidebar-width: 300px
    body-width: 800px
    margin-width: 200px
  image: /public/quarto-gradio-bg.png
  title: Overview
  description: A Quarto extension enabling the embedding of serverless Gradio Lite apps into HTML documents.
  

Output created: _site/index.html


