pandoc 

  to: html
  output-file: template.html
  standalone: true
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  toc: true
  variables: {}
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  theme:
    - default
    - _extensions/julia/custom.scss
  engines:
    - path: /opt/quarto/share/extension-subtrees/julia-engine/_extensions/julia-engine/julia-engine.js
  title: Julia-themed Quarto
  author: pat-alt
  date: last-modified
  

