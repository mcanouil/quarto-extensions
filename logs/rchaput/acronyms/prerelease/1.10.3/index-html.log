

pandoc 

  to: html
  output-file: index.html
  standalone: true
  title-prefix: acronyms
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  toc: true
  variables: {}
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  engines:
    - path: /opt/quarto/share/extension-subtrees/julia-engine/_extensions/julia-engine/julia-engine.js
  theme: cosmo
  title: Advanced usage tutorials
  listing:
    type: default
    sort: date
    fields:
      - title
      - description
    exclude:
      title: Advanced usage tutorials
    sort-ui: false
  

