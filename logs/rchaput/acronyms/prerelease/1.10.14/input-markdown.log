pandoc 

  to: markdown
  output-file: input.md
  standalone: true
  default-image-extension: png
  markdown-headings: atx
  wrap: preserve
  

metadata

  keep-yaml: false
  acronyms:
    sorting: alphabetical-case-insensitive
    include_unused: false
    keys:
      - shortname: Qt
        longname: Quarto
      - shortname: iQt
        longname: inside-Quarto
      - shortname: aA
        longname: alphabetically
      - shortname: H
        longname: handle
  

