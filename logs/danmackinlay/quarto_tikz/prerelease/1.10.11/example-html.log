pandoc 

  to: html
  output-file: example.html
  standalone: true
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  title: TikZ Example
  tikz:
    cache: false
    save-tex: true
    tex-dir: tikz-tex
  

