pandoc 

  to: revealjs
  output-file: demo-custom.html
  standalone: true
  wrap: none
  default-image-extension: png
  html-math-method:
    method: mathjax
    url: >-
      https://cdn.jsdelivr.net/npm/mathjax@2.7.9/MathJax.js?config=TeX-AMS_HTML-full
  slide-level: 2
  css:
    - css/mycustomstyle.css
  section-divs: true
  

metadata

  link-citations: true
  width: 1050
  height: 700
  margin: 0.1
  center: true
  navigationMode: grid
  controlsLayout: bottom-right
  controlsTutorial: false
  hash: true
  history: true
  hashOneBasedIndex: false
  fragmentInURL: false
  transition: slide
  backgroundTransition: fade
  pdfSeparateFragments: false
  lang: en
  auto-stretch: true
  title: Simplemenu
  subtitle: For Reveal.js and Quarto, using custom styling
  revealjs-plugins:
    - simplemenu
  title-slide-attributes:
    data-state: hide-menubar
  theme: default
  slideNumber: c/t
  chalkboard: false
  menu: false
  simplemenu:
    barhtml:
      header: <div class='menubar'><a class='logo' href='#'><img src='img/logo.svg'></a><ul class='menu'></ul><div class='slide-number'></div><div>
    scale: 0.8
  

