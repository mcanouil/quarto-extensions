pandoc 

  to: latex
  output-file: example_data_classification_label.tex
  standalone: true
  pdf-engine: lualatex
  variables:
    graphics: true
    tables: true
  default-image-extension: pdf
  toc: false
  

metadata

  block-headings: true
  toc-title: Contents
  cover_page: true
  letterhead: false
  dark_background: false
  urlcolor: magenta
  linkcolor: magenta
  colorlinks: true
  page_numbers: true
  paragraph_numbers: false
  papersize: a4
  disable_justify: false
  geometry:
    - top=60mm
  letterhead_img: bgwhite.jpg
  letterhead_img_darkbg: bgdark.jpg
  cover_illustration_img: cover-ill.png
  cover_illustration_img_darkbg: cover-ill.png
  classoption: table
  title: Data Classification Label Example
  subtitle: Demonstrating document security classification
  author: TeXnative Documentation
  date: last-modified
  data_classification_label:
    level: confidential
    levels:
      confidential:
        bgcolor: '#ff0000'
        txtcolor: '#ffffff'
        txt: CONFIDENTIAL
      internal:
        bgcolor: '#ee7d2f'
        txtcolor: '#000000'
        txt: INTERNAL
      public:
        bgcolor: '#70ac45'
        txtcolor: '#000000'
        txt: PUBLIC
    width: 35mm
    height: 8mm
    top: 10mm
    left: 10mm
    txtsize: small
    border-radius: 3pt
  


