pandoc 

  to: html
  output-file: cover-page.html
  standalone: true
  title-prefix: TeXnative
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  toc: true
  variables: {}
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  theme:
    light:
      - cosmo
      - theme.scss
    dark:
      - cosmo
      - theme-dark.scss
  code-copy: true
  title: Cover Page
  

Output created: _site/cover-page.html


