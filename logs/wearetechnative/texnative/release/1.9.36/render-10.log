pandoc 

  to: latex
  output-file: example_tables_frontmatter_configured.tex
  standalone: true
  pdf-engine: lualatex
  variables:
    graphics: true
    tables: true
  default-image-extension: pdf
  toc: false
  

metadata

  block-headings: true
  toc-title: Contents
  cover_page: true
  letterhead: false
  dark_background: true
  urlcolor: magenta
  linkcolor: magenta
  colorlinks: true
  page_numbers: true
  paragraph_numbers: false
  papersize: a4
  disable_justify: false
  geometry:
    - top=60mm
  letterhead_img: bgwhite.jpg
  letterhead_img_darkbg: bgdark.jpg
  cover_illustration_img: cover-ill.png
  cover_illustration_img_darkbg: cover-ill.png
  classoption: table
  engines:
    - path: /opt/quarto/share/extension-subtrees/julia-engine/_extensions/julia-engine/julia-engine.js
  table-header-bgcolor: 0,200,0
  table-header-txtcolor: 50,50,50
  table-body-bgcolor: 200,0,0
  table-body-txtcolor: 250,250,250
  table-border-color: 0,0,0
  table-border-width: 3
  table-cell-padding: 20
  table-alignment: center
  


