        section-title-footnotes: Fußnoten
        section-title-references: Literatur
        section-title-reuse: Wiederverwendung
        section-title-copyright: Urheberrechte
        section-title-citation: Zitat
        appendix-attribution-cite-as: 'Bitte zitieren Sie diese Arbeit als:'
        appendix-attribution-bibtex: 'Mit BibTeX zitieren:'
        appendix-view-license: Lizenz Anzeigen
        title-block-author-single: Autor:in
