        listing-page-category-all: alle
        listing-page-no-matches: Keine Treffer
        listing-page-words: '{0} Wörter'
        listing-page-filter: Filter
        draft: Entwurf
  default-image-extension: pdf
  cite-method: biblatex
  

metadata

  block-headings: true
  documentclass: moderncv
  moderncvtheme: classic
  cvoption: blue
  biblatexoptions:
    - style=apa
    - backend=biber
    - sortcites=true
    - sorting=ydnt
  lang: de
  date-format: DD.MM.YYYY
  subbibliography: false
  linkcolor: black
  date: '2022-12-24'
  vorname: Prof. Dr. Georg
  nachname: Mustermann
  strasse: Reinarzstr. 49
  plz: 47805
  ort: Krefeld
  graduate: Professor für Alles
  telefon: +49 555 822 5555
  email: mustermann@hs-niederrhein.de
  passbild: foto.png
  extrainfo: 'orcid: 0000-0002-XXXX-YYYY'
  bibliography:
    - literatur.bib
  publikationen:
    - list:
        key: auswahl
        title: Publikationen (Auswahl)
  


