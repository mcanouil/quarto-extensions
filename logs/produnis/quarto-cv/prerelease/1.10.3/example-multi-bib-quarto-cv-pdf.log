pandoc 

  to: latex
  output-file: example-multi-bib.tex
  template: _extensions/quarto-cv/template.tex
  standalone: true
  pdf-engine: pdflatex
  variables:
    graphics: true
    tables: true
  default-image-extension: pdf
  cite-method: biblatex
  

metadata

  block-headings: true
  documentclass: moderncv
  moderncvtheme: casual
  cvoption: green
  biblatexoptions:
    - style=apa
    - backend=biber
    - sortcites=true
    - sorting=ydnt
  lang: de
  date-format: DD.MM.YYYY
  subbibliography: true
  linkcolor: black
  engines:
    - path: /opt/quarto/share/extension-subtrees/julia-engine/_extensions/julia-engine/julia-engine.js
  date: '2022-12-24'
  vorname: Prof. Dr. Georg
  nachname: Mustermann
  strasse: Reinarzstr. 49
  plz: 47805
  ort: Krefeld
  graduate: Professor für Alles
  telefon: +49 555 822 5555
  email: mustermann@hs-niederrhein.de
  passbild: foto.png
  extrainfo: 'orcid: 0000-0002-XXXX-YYYY'
  bibliography:
    - literatur.bib
  publikationen:
    - list:
        key: journal
        title: Zeitschriftenartikel (peer-reviewed)
    - list:
        key: buch
        title: Bücher
    - list:
        key: buchkapitel
        title: Buchkapitel
    - list:
        key: konferenz
        title: Konferenzbeiträge (peer-reviewed)
  


