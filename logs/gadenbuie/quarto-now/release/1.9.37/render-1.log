pandoc 

  to: html
  output-file: README.html
  standalone: true
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  css:
    - auto-dark-mode.css
  toc: true
  variables: {}
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  engines:
    - path: /opt/quarto/share/extension-subtrees/julia-engine/_extensions/julia-engine/julia-engine.js
  title: now
  subtitle: A Quarto extension for inserting the current or last modified date and time
  modified: '2006-05-04 12:34:56'
  toc-level: 2
  toc-location: right
  toc-title: now
  code-links:
    - text: gadenbuie/quarto-now
      href: https://github.com/gadenbuie/quarto-now
      icon: github
    - text: Question or Issue?
      href: https://github.com/gadenbuie/quarto-now/issues/new
      icon: question-circle-fill
  

Output created: README.html


