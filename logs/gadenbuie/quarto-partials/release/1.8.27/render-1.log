pandoc 

  to: html
  output-file: README.html
  standalone: true
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  toc: true
  variables: {}
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  title: Partial content templates for Quarto
  subtitle: Embed partial content in Quarto easily.
  partial-data:
    name: friend
  my-data:
    friends:
      name: amigo
  toc-level: 2
  toc-location: right
  toc-title: quarto-partials
  code-links:
    - text: gadenbuie/quarto-partials
      href: https://github.com/gadenbuie/quarto-partials
      icon: github
    - text: Question or Issue?
      href: https://github.com/gadenbuie/quarto-partials/issues/new
      icon: question-circle-fill
  

Output created: README.html


