pandoc 

  to: html
  output-file: README.html
  standalone: true
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  toc: true
  variables: {}
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  engines:
    - path: /opt/quarto/share/extension-subtrees/julia-engine/_extensions/julia-engine/julia-engine.js
  title: Tachyons Extension For Quarto
  toc-level: 2
  toc-location: right
  toc-title: tachyons
  code-links:
    - text: gadenbuie/quarto-tachyons
      href: https://github.com/gadenbuie/quarto-tachyons
      icon: github
    - text: Question or Issue?
      href: https://github.com/gadenbuie/quarto-tachyons/issues/new
      icon: question-circle-fill
  

Output created: README.html


