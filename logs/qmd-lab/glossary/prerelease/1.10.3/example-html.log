pandoc 

  to: html
  output-file: example.html
  standalone: true
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  variables: {}
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  engines:
    - path: /opt/quarto/share/extension-subtrees/julia-engine/_extensions/julia-engine/julia-engine.js
  title: Glossary Example
  glossary:
    - id: my-glossary
      class: definition
      contents:
        - ex*
  

