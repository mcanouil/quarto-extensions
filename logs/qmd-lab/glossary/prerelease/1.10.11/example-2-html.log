pandoc 

  to: html
  output-file: example-2.html
  standalone: true
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  title: Glossary Example 2
  subtitle: Two different glossaries on one page
  glossary:
    - id: my-defs
      class: definition
      contents:
        - ex*
    - id: my-fns
      class: function
      contents:
        - ex*
  

