pandoc 

  to: revealjs
  output-file: index.html
  standalone: true
  wrap: none
  default-image-extension: png
  html-math-method:
    method: mathjax
    url: >-
      https://cdn.jsdelivr.net/npm/mathjax@2.7.9/MathJax.js?config=TeX-AMS_HTML-full
  slide-level: 2
  css:
    - _extensions/onyxia/logo.css
  email-obfuscation: javascript
  variables: {}
  

metadata

  link-citations: true
  width: 1050
  height: 700
  margin: 0.1
  center: false
  navigationMode: linear
  controlsLayout: edges
  controlsTutorial: false
  hash: true
  history: true
  hashOneBasedIndex: false
  fragmentInURL: false
  transition: none
  backgroundTransition: none
  pdfSeparateFragments: false
  lang: en
  auto-stretch: true
  theme:
    - default
    - _extensions/onyxia/onyxia.scss
  title-slide-attributes:
    data-background-image: _extensions/onyxia/background.svg
    data-background-size: contain
  header-includes:
    - |
      <link rel="icon" type="image/png" sizes="32x32" href="favicon-32x32.png">
  title: Onyxia
  subtitle: |
    **[The open source\
    cloud native\
    data science platform]{.orange}**
  author: |
    [InseeFrLab](https://github.com/InseeFrLab)
  date: today
  slideNumber: true
  footer: |
    **[onyxia.sh](https://www.onyxia.sh)**
  slide-tone: true
  chalkboard:
    theme: whiteboard
  editor:
    render-on-save: true
  

Output created: index.html


