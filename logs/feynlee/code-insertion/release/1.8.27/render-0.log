pandoc 

  to: html
  output-file: example.html
  standalone: true
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  variables: {}
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  title: Code-insertion Example
  insert-before-post: before_post.md
  insert-after-post: after_post.md
  

Output created: example.html


