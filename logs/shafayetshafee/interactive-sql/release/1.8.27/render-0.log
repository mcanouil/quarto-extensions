pandoc 

  to: html
  output-file: example.html
  standalone: true
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  variables: {}
  

metadata

  document-css: false
  link-citations: true
  lang: en
  title: Interactive-sql Example
  subtitle: Run SQL Interactively from HTML Documents Made with Quarto
  author: Shafayet Khan Shafee
  date: last-modified
  date-format: DD MMM, YYYY
  databases:
    - name: hr
      path: https://raw.githubusercontent.com/shafayetShafee/interactive-sql/main/hr.sql
    - name: hr-not-editable
      path: https://raw.githubusercontent.com/shafayetShafee/interactive-sql/main/hr.sql
      editable: false
  

Output created: example.html


