

pandoc 

  to: latex
  output-file: index.tex
  standalone: true
  toc: true
  number-sections: false
  top-level-division: chapter
  pdf-engine: lualatex
  variables:
    graphics: true
    tables: true
  default-image-extension: pdf
  reference-location: margin
  toc-depth: 2
  cite-method: natbib
  

metadata

  crossref:
    chapters: true
  documentclass: tufte-book
  papersize: letter
  block-headings: true
  bibliography:
    - references.bib
  engines:
