  citation-location: margin
  fig-cap-location: bottom
  classoption:
    - sfsidenotes
  toc-title: Contents
  indent: 0px
  mainfont: ETbb
  sansfont: TeX Gyre Heros
  sansfontoptions: Scale=MatchUppercase
  title: |
    Tufte-Quarto Project Type\
    Documentation
  author: Fred Guth
  date-format: MMMM, YYYY
  


