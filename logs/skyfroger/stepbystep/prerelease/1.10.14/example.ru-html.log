pandoc 

  to: html
  output-file: example.ru.html
  standalone: true
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  toc: true
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: ru
  title: Stepbystep
  stepbystep:
    headers-level: 4
  

Output created: example.ru.html


