pandoc 

  to: html
  output-file: example.html
  standalone: true
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  toc: true
  toc-depth: 3
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  title: Stepbystep
  

Output created: example.html


