pandoc 

  to: html
  output-file: example.ru.html
  standalone: true
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: ru
  title: Python IDE в браузере
  qcode:
    inline-doc: true
  

Output created: example.ru.html


