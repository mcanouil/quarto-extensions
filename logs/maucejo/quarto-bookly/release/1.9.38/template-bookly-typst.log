pandoc 

  to: typst
  output-file: template.typ
  standalone: true
  default-image-extension: svg
  wrap: none
  citeproc: false
  toc: true
  variables: {}
  

metadata

  engines:
    - path: /opt/quarto/share/extension-subtrees/julia-engine/_extensions/julia-engine/julia-engine.js
  title: Bookly Typst - Complete Template
  subtitle: Quarto extension usage example
  author: Your Name
  date: today
  lang: en
  lof: true
  lot: true
  theme: modern
  tufte: false
  fonts:
    body: Lato
    math: Lete Sans Math
  part-numbering: A
  config-options:
    open-right: true
    alt-margins: false
  colors:
    primary: rgb("#1d90d0")
    secondary: rgb("#dddddd").darken(15%)
  

