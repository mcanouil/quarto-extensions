pandoc 

  to: html
  output-file: example-parens.html
  standalone: true
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  variables: {}
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  engines:
    - path: /opt/quarto/share/extension-subtrees/julia-engine/_extensions/julia-engine/julia-engine.js
  title: Parenthesized Roman Numerals
  extensions:
    footnote-styles:
      style: roman-lower
      marker-prefix: (
      marker-suffix: )
      text-prefix: (
      text-suffix: )
  

Output created: example-parens.html


