pandoc 

  to: typst
  output-file: example-continuation.typ
  standalone: true
  shift-heading-level-by: -1
  default-image-extension: svg
  wrap: none
  citeproc: false
  variables: {}
  

metadata

  engines:
    - path: /opt/quarto/share/extension-subtrees/julia-engine/_extensions/julia-engine/julia-engine.js
  title: Continuing from a Previous Document
  extensions:
    footnote-styles:
      style: roman-lower
      text-suffix: .
      start-at: 4
  

