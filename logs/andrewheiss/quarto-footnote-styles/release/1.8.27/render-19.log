pandoc 

  to: html
  output-file: example-custom-restart.html
  standalone: true
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  variables: {}
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  title: Custom Symbols (Restart)
  extensions:
    footnote-styles:
      custom:
        - ★
        - ◆
        - ●
        - ■
      cycle: restart
  

Output created: example-custom-restart.html


