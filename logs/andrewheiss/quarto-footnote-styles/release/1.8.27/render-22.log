pandoc 

  to: html
  output-file: example-alpha-paren.html
  standalone: true
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  variables: {}
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  title: Letters with Parenthesis
  extensions:
    footnote-styles:
      style: alpha-lower
      text-suffix: )
  

Output created: example-alpha-paren.html


