pandoc 

  to: html
  output-file: example-roman-period.html
  standalone: true
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  variables: {}
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  title: Roman Numerals with Period
  extensions:
    footnote-styles:
      style: roman-lower
      text-suffix: .
  

Output created: example-roman-period.html


