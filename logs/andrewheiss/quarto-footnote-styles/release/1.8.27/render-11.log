pandoc 

  to: latex
  output-file: example-padded.tex
  standalone: true
  pdf-engine: lualatex
  variables:
    graphics: true
    tables: true
  default-image-extension: pdf
  

metadata

  documentclass: scrartcl
  classoption:
    - DIV=11
    - numbers=noendperiod
  papersize: letter
  header-includes:
    - \KOMAoption{captions}{tableheading}
  block-headings: true
  title: Zero-Padded Numbers with Period
  extensions:
    footnote-styles:
      style: numeric-02
      text-suffix: .
  


