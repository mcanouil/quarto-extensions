pandoc 

  to: html
  output-file: example-continuation.html
  standalone: true
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  variables: {}
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  title: Continuing from a Previous Document
  extensions:
    footnote-styles:
      style: roman-lower
      text-suffix: .
      start-at: 4
  

Output created: example-continuation.html


