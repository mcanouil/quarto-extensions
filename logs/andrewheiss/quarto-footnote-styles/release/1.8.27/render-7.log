pandoc 

  to: html
  output-file: example-parens.html
  standalone: true
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  variables: {}
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  title: Parenthesized Roman Numerals
  extensions:
    footnote-styles:
      style: roman-lower
      marker-prefix: (
      marker-suffix: )
      text-prefix: (
      text-suffix: )
  

Output created: example-parens.html


