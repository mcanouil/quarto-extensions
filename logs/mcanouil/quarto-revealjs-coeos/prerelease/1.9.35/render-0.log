pandoc 

  to: revealjs
  output-file: index.html
  standalone: true
  wrap: none
  default-image-extension: png
  html-math-method:
    method: mathjax
    url: >-
      https://cdn.jsdelivr.net/npm/mathjax@2.7.9/MathJax.js?config=TeX-AMS_HTML-full
  slide-level: 2
  variables: {}
  

metadata

  link-citations: true
  width: 1050
  height: 700
  margin: 0.1
  center: false
  navigationMode: linear
  controlsLayout: edges
  controlsTutorial: false
  hash: true
  history: true
  hashOneBasedIndex: false
  fragmentInURL: false
  transition: none
  backgroundTransition: none
  pdfSeparateFragments: true
  lang: en
  auto-stretch: true
  theme: _extensions/coeos/coeos.scss
  mermaid:
    theme: dark
  date-format: dddd[, the] Do [of] MMMM, YYYY
  slideNumber: c
  code-annotations: select
  footer: |
    <a href="https://mickael.canouil.fr/">mickael.canouil.fr</a>
    |
    <a href="https://creativecommons.org/licenses/by-sa/4.0/">License: CC-BY-SA-4.0</a>
  logo: _extensions/coeos/coeos.svg
  engines:
    - path: /opt/quarto/share/extension-subtrees/julia-engine/_extensions/julia-engine/julia-engine.js
  title: A Title
  subtitle: A Subtitle
  author: Mickaël Canouil, *Ph.D.*
  institute: Freelance
  date: today
  

Output created: index.html


