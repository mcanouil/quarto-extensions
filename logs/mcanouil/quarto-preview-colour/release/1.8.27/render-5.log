pandoc 

  to: latex
  output-file: example-xelatex.tex
  standalone: true
  embed-resources: true
  pdf-engine: lualatex
  variables:
    graphics: true
    tables: true
  default-image-extension: pdf
  

metadata

  documentclass: scrartcl
  classoption:
    - DIV=11
    - numbers=noendperiod
  papersize: a4
  header-includes:
    - \KOMAoption{captions}{tableheading}
  block-headings: true
  title: Preview Colour Example
  subtitle: Quarto Extension
  author:
    - name: Mickaël CANOUIL, _Ph.D._
      orcid: 0000-0002-3396-4549
      url: https://mickael.canouil.fr
  extensions:
    preview-colour:
      code: true
      text: true
      glyph:
        default: ●
        html: '&#9673;'
        latex: \\textbullet
        typst: ◉
        docx: ●
        pptx: ●
  margin:
    x: 2.5cm
    'y': 2.5cm
  

