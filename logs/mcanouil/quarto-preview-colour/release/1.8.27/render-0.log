pandoc 

  to: beamer
  output-file: example.tex
  standalone: true
  embed-resources: true
  pdf-engine: lualatex
  variables:
    graphics: true
    tables: true
  default-image-extension: pdf
  

metadata

  block-headings: true
  title: Preview Colour Example
  subtitle: Quarto Extension
  author:
    - name: Mickaël CANOUIL, _Ph.D._
      orcid: 0000-0002-3396-4549
      url: https://mickael.canouil.fr
  extensions:
    preview-colour:
      code: true
      text: true
      glyph:
        default: ●
        html: '&#9673;'
        latex: \\textbullet
        typst: ◉
        docx: ●
        pptx: ●
  aspectratio: 169
  

