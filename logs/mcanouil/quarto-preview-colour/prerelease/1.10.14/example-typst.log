pandoc 

  to: typst
  output-file: example.typ
  standalone: true
  embed-resources: true
  shift-heading-level-by: -1
  default-image-extension: svg
  wrap: none
  citeproc: false
  

metadata

  title: Preview Colour Example
  subtitle: Quarto Extension
  author:
    - name: Mickaël CANOUIL, _Ph.D._
      orcid: 0000-0002-3396-4549
      url: https://mickael.canouil.fr
  extensions:
    preview-colour:
      code: true
      text: true
      json: example-colours.json
      glyph:
        default: ●
        html: '&#9673;'
        latex: \\textbullet
        typst: ◉
        docx: ●
        pptx: ●
  papersize: a4
  margin:
    x: 2.5cm
    'y': 2.5cm
  

