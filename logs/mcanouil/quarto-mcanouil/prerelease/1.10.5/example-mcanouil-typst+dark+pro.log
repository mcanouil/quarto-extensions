metadata

  columns: 1
  author:
    - name:
        given: Mickaël
        family: CANOUIL
      degrees: Ph.D.
      email: pro@mickael.canouil.dev
      orcid: 0000-0002-3396-4549
      url: https://mickael.canouil.fr
      attributes:
        corresponding: true
      affiliations:
        - name: Independent Contractor
          city: Lille
          country: France
    - name:
        given: Jane
        family: Doe
      orcid: 0000-0001-2345-6789
      affiliations:
        - name: Example University
          department: Department of Statistics
          city: London
          country: United Kingdom
  copyright: © 2026 Mickaël CANOUIL
  license: CC BY-NC-SA
  lang: en-GB
  code-copy: true
  date: today
  date-format: dddd[, the] Do [of] MMMM, YYYY
  mermaid:
    theme: dark
  extensions:
    mcanouil:
      grid-background: true
  document-type: report
  brand-mode: dark
  style: professional
  show-corner-brackets: true
  show-margin-decoration: true
  show-title-page-background: true
  show-heading-underlines: true
  show-logo: true
  logo:
    light:
      path: dark
      alt: Mickaël CANOUIL Logo
      width: 7cm
    dark:
      path: light
      alt: Mickaël CANOUIL Logo
      width: 7cm
  orcid-icon: _extensions/mcanouil/typst/assets/orcid.svg
  mainfont: Alegreya Sans
  sansfont: Alegreya Sans
  fontsize: 11pt
  papersize: a4
  margin:
    top: 2.5cm
    bottom: 2.5cm
    left: 2.5cm
    right: 2.5cm
  title-page: true
  section-numbering: 1.1.1.
  section-page: true
  section-pagebreak: true
  special-sections:
    references:
      name: References
      numbering: none
      prefix: false
    appendix:
      name: Appendix
      numbering: A.a.
      prefix: true
    supplementary:
      name: Supplementary
      numbering: I.i.
      prefix: true
  list-of: true
  bibliographystyle: apa
  title: Mickaël CANOUIL Template
  subtitle: Complete Guide
  date-modified: today
  abstract: |
    This document showcases all features of the Mickaël CANOUIL template for Quarto, spanning HTML, Typst (PDF), and Reveal.js (presentations) formats.
    It demonstrates template-specific components including value boxes, info panels, status badges, dividers, progress bars, cards, card grids, executive summaries, and highlighted blocks.
    Additionally, it covers standard Quarto features such as figures, tables, mathematical notation, callouts, code blocks, code annotations, mermaid diagrams, and cross-references.
    Use this document as both a learning resource and a quick reference guide for all available template capabilities.
  keywords:
    - Quarto
    - Typst
    - Template
    - Documentation
    - Tutorial
  crossref:
    custom:
      - kind: float
        reference-prefix: Text
        key: txt
  references:
    - id: example_2024
      author:
        - family: Example
          given: Jane
        - family: Author
          given: John
      container-title: Journal of Examples
      doi: 10.1234/example.2024
      issued: 2024
      title: An Example Article for Demonstrating Citations
      type: article-journal
  other-links:
    - text: HTML (Academic Style)
      href: example-academic.html
      target: _blank
      rel: noopener noreferrer
  watermark-text: DEMO
  

