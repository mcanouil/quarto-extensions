metadata

  link-citations: true
  width: 1050
  height: 700
  margin: 0.1
  center: false
  navigationMode: linear
  controlsLayout: edges
  controlsTutorial: false
  hash: true
  history: true
  hashOneBasedIndex: false
  fragmentInURL: false
  transition: slide
  backgroundTransition: none
  pdfSeparateFragments: false
  lang: en-GB
  auto-stretch: true
  author:
    - name:
        given: Mickaël
        family: CANOUIL
      degrees: Ph.D.
      email: pro@mickael.canouil.dev
      orcid: 0000-0002-3396-4549
      url: https://mickael.canouil.fr
      attributes:
        corresponding: true
      affiliations:
        - name: Independent Contractor
          city: Lille
          country: France
    - name:
        given: Jane
        family: Doe
      orcid: 0000-0001-2345-6789
      affiliations:
        - name: Example University
          department: Department of Statistics
          city: London
          country: United Kingdom
  copyright: © 2026 Mickaël CANOUIL
  license: CC BY-NC-SA
  code-copy: true
  date: today
  date-format: dddd[, the] Do [of] MMMM, YYYY
  mermaid:
    theme: dark
  extensions:
    mcanouil:
      grid-background: true
      section-outline: true
      date-superscript: true
      hide-title-slide-chrome: true
      favicon-from-logo: true
      code-annotation-fragments: true
      debug-borders: false
  brand-mode: dark
  logo:
    light: light
    dark: dark
  theme:
    - default
    - _extensions/mcanouil/revealjs/theme.scss
    - brand
  revealjs-plugins:
    - /home/runner/work/quarto-extensions/quarto-extensions/test-9/repo/_extensions/mcanouil/revealjs-plugin/mcanouil
    - /home/runner/work/quarto-extensions/quarto-extensions/test-9/repo/_extensions/mcanouil/revealjs-plugin/tabset
    - /home/runner/work/quarto-extensions/quarto-extensions/test-9/repo/_extensions/mcanouil/revealjs-plugin/line-fragment-indices
    - /home/runner/work/quarto-extensions/quarto-extensions/test-9/repo/_extensions/mcanouil/revealjs-plugin/code-annotation-fragments
  slideNumber: c
  code-annotations: select
  footer: |
    <a href="https://mickael.canouil.fr/" target="_blank" rel="noopener noreferrer">mickael.canouil.fr</a>
    |
    <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" target="_blank" rel="noopener noreferrer">License: CC BY-NC-SA 4.0</a>
  closing-slide:
    photo: https://github.com/mcanouil.png
    social:
      website: https://mickael.canouil.fr
      github: mcanouil
      linkedin: MickaelCanouil
      bluesky: mickael.canouil.fr
      mastodon: https://fosstodon.org/%40MickaelCanouil
  title: Mickaël CANOUIL Template
  subtitle: Complete Guide
  date-modified: today
  abstract: |
    This document showcases all features of the Mickaël CANOUIL template for Quarto, spanning HTML, Typst (PDF), and Reveal.js (presentations) formats.
    It demonstrates template-specific components including value boxes, info panels, status badges, dividers, progress bars, cards, card grids, executive summaries, and highlighted blocks.
    Additionally, it covers standard Quarto features such as figures, tables, mathematical notation, callouts, code blocks, code annotations, mermaid diagrams, and cross-references.
    Use this document as both a learning resource and a quick reference guide for all available template capabilities.
  keywords:
    - Quarto
    - Typst
    - Template
    - Documentation
    - Tutorial
  crossref:
    custom:
      - kind: float
        reference-prefix: Text
        key: txt
  references:
    - id: example_2024
      author:
        - family: Example
          given: Jane
        - family: Author
          given: John
      container-title: Journal of Examples
      doi: 10.1234/example.2024
      issued: 2024
      title: An Example Article for Demonstrating Citations
      type: article-journal
  style: professional
  other-links:
    - text: HTML (Academic Style)
      href: example-academic.html
      target: _blank
      rel: noopener noreferrer
  scrollable: true
  smaller: true
  

Output created: example-revealjs-dark.html


