  title: Imagify Example
  imagify:
    scope: all
    embed: false
    lazy: true
    output-folder: _imagify_files
    pdf-engine: latex
    zoom: 1.5
  imagify-classes:
    highlightme:
      zoom: 4
      block-style: 'border: 1px solid red;'
      debug: false
    fitch:
      header-includes: \usepackage{fitch}
      debug: false
  

