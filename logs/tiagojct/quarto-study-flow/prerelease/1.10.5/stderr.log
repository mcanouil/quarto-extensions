      - label: Exposed
        'n': 3100
        lost_followup: 220
        lost_reasons:
          - 'Moved out of catchment: 140'
          - 'Withdrew consent: 80'
        analysed: 2880
      - label: Unexposed
        'n': 4100
        lost_followup: 310
        lost_reasons:
          - 'Moved out of catchment: 200'
          - 'Withdrew consent: 110'
        analysed: 3790
  
