metadata
  document-css: false
  link-citations: true
  date-format: long
  lang: en
  title: PRISMA 2020 flow diagram example
  study-flow:
    type: prisma
    identification:
      databases: 1842
      registers: 167
      duplicates_removed: 612
      ineligible_automation: 88
      other_removed: 14
    screening:
      screened: 1295
      excluded: 1024
      sought_retrieval: 271
      not_retrieved: 23
      assessed: 248
      excluded_with_reasons:
        - Wrong population (n=46)
        - Wrong intervention (n=31)
        - Wrong outcome (n=22)
        - Wrong study design (n=18)
        - Conference abstract only (n=11)
    other_methods:
      websites: 12
      organisations: 8
      citation_searching: 25
      sought_retrieval: 41
      not_retrieved: 3
      assessed: 38
      excluded_with_reasons:
        - Wrong population (n=5)
        - Wrong outcome (n=4)
    included:
      studies: 134
      reports: 142
  
