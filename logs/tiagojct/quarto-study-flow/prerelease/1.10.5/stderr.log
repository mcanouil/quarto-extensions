      - 'Declined consent: 34'
      - 'Withdrew before testing: 11'
    enrolled: 475
    index_test: 461
    not_index: 14
    not_index_reasons:
      - 'Equipment malfunction: 8'
      - 'Sample not collected: 6'
    reference_standard: 442
    not_reference: 19
    not_reference_reasons:
      - 'Refused reference test: 12'
      - 'Reference test contraindicated: 7'
    outcomes:
      true_positive: 148
      false_positive: 41
      false_negative: 27
      true_negative: 226
  
