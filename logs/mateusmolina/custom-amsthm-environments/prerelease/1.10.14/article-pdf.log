pandoc 

  to: latex
  output-file: article.tex
  standalone: true
  shift-heading-level-by: -1
  pdf-engine: lualatex
  variables:
    graphics: true
    tables: true
  default-image-extension: pdf
  number-sections: true
  

metadata

  block-headings: true
  title: Test Article for Custom AmSThm Environments
  author: Test Author
  date: today
  custom-amsthm:
    - key: prm
      name: Problem
      numbering-style: section
    - key: tsk
      name: Task
      numbering-style: global
    - key: usecase
      name: Use Case
      numbered: false
  documentclass: article
  


