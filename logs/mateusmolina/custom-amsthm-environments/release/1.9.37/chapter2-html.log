pandoc 

  to: html
  output-file: chapter2.html
  standalone: true
  toc: true
  number-sections: true
  title-prefix: Test Book for Custom AmSThm Environments
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  number-offset:
    - 2
  variables: {}
  

metadata

  crossref:
    chapters: true
  document-css: false
  link-citations: true
  date-format: long
  lang: en
  custom-amsthm:
    - key: prm
      name: Problem
    - key: tsk
      name: Task
      numbering-style: global
  engines:
    - path: /opt/quarto/share/extension-subtrees/julia-engine/_extensions/julia-engine/julia-engine.js
  theme: cosmo
  title: "[2]{.chapter-number}\_ [Chapter 2: Basic Examples]{.chapter-title}"
  hide-description: true
  

Output created: _output/chapter2.html


