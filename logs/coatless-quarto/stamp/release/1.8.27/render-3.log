pandoc 

  to: html
  output-file: qstamp-custom-placement.html
  standalone: true
  title-prefix: colab
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  toc: true
  variables: {}
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  title: Stamp Example
  stamp:
    level: minimal
    placement: custom
    placement-id: a-stamp-id
  

