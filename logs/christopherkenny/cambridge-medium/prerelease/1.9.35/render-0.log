pandoc 

  to: latex
  output-file: template.tex
  standalone: true
  shift-heading-level-by: -1
  pdf-engine: pdflatex
  variables:
    graphics: true
    tables: true
  default-image-extension: pdf
  toc: false
  number-sections: true
  cite-method: biblatex
  

