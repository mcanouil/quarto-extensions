pandoc 

  to: html
  output-file: example.html
  standalone: true
  section-divs: true
  html-math-method: mathjax
  wrap: none
  default-image-extension: png
  pdf-engine: latexmk
  

metadata

  document-css: false
  link-citations: true
  date-format: long
  lang: en
  title: Critic-markdown Example
  

Output created: example.html


